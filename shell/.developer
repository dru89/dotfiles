#!/usr/bin/env sh

# Developer directory management
# ==============================
#
# All git repos live under $DEVELOPER_DIR (defaults to ~/Developer), organized
# by remote URL: <host>/<org>/<repo>. The functions in this file handle
# cloning, navigation, worktree management, and path auditing.
#
# Quick reference
# ---------------
#
# Cloning:
#   clone <url>           Standard clone to $DEVELOPER_DIR/<host>/<org>/<repo>
#   clone --wt <url>      Clone as a worktree container (bare db + initial worktree)
#   clone <org-url>       Clone all repos in a GitHub org or GitLab group
#
# Navigation:
#   cdr [query]           Fuzzy-pick a repo under $DEVELOPER_DIR (frecency-ranked)
#   cdw [query]           Fuzzy-pick a writing project under ~/Writing
#
# Worktrees:
#   wt add <branch>       Create a new worktree (and branch) in the current container
#   wt [query]            List worktrees for current repo, fzf to pick one
#   wt rm <branch>        Remove a worktree (and optionally delete the branch)
#   convert-wt            Convert the current standard clone into a worktree container
#
# Maintenance:
#   reorg [--apply]       Audit repos and fix paths that don't match their remote
#
# Repo layouts
# ------------
# Repos exist in one of two layouts at the <repo> leaf:
#
# Standard clone (most repos):
#   ~/Developer/github.com/org/repo/
#   ├── .git/          ← directory
#   ├── src/
#   └── ...
#
# Worktree container (repos needing multiple branches checked out):
#   ~/Developer/github.com/org/repo/
#   ├── .bare/         ← bare git object store
#   ├── .git           ← file (not directory), contains "gitdir: .bare"
#   ├── main/          ← worktree for main branch
#   ├── feature-x/     ← worktree for feature-x branch
#   └── ...
#
# Detection: check whether .git is a directory (standard clone) or a file.
# If the file's contents point to .bare, you're at the container level.
# If it points to a path containing .git/worktrees/, you're inside a worktree.
# Use _wt_container_root to resolve the container root from anywhere inside.

# ---------------------------------------------------------------------------
# Prune list — directories to skip during find traversals
# ---------------------------------------------------------------------------
_DEVELOPER_PRUNE_DIRS=(
    node_modules .venv venv __pycache__ .tox vendor
    target build dist .next .cache
)

# Build -prune clause for find. Usage: find "$root" $(_developer_prune_args) ...
_developer_prune_args() {
    local first=true
    printf '%s' '\('
    for d in "${_DEVELOPER_PRUNE_DIRS[@]}"; do
        $first || printf '%s' ' -o'
        printf ' -name "%s"' "$d"
        first=false
    done
    printf '%s' ' \) -type d -prune -o'
}

# ---------------------------------------------------------------------------
# URL parsing helpers
# ---------------------------------------------------------------------------

# Extract hostname from a git URL (SSH, ssh://, or HTTPS).
_clone_parse_host() {
    local norm="${1%.git}"
    if [[ "$norm" == git@* ]]; then
        local h="${norm#git@}"; echo "${h%%:*}"
    elif [[ "$norm" == ssh://* ]]; then
        local h="${norm#ssh://}"; h="${h#*@}"; h="${h%%/*}"; echo "${h%%:*}"
    else
        local h="${norm#*://}"; echo "${h%%/*}"
    fi
}

# Extract the path component (no host, no .git) from a git URL.
_clone_parse_path() {
    local norm="${1%.git}"
    if [[ "$norm" == git@* ]]; then
        echo "${norm#*:}"
    elif [[ "$norm" == ssh://* ]]; then
        local p="${norm#ssh://}"; p="${p#*@}"; echo "${p#*/}"
    else
        local p="${norm#*://}"; echo "${p#*/}"
    fi
}

# ---------------------------------------------------------------------------
# Worktree detection helpers
# ---------------------------------------------------------------------------

# Print the worktree container root if we're inside one, empty string otherwise.
# Works from the container level, from inside a worktree, or from a subdirectory
# of either. Returns 1 if the repo is a standard clone (not a worktree container).
_wt_container_root() {
    local git_common_dir
    git_common_dir=$(git rev-parse --git-common-dir 2>/dev/null) || return 1

    # Resolve to absolute path.
    [[ "$git_common_dir" != /* ]] && git_common_dir="$(cd "$(git rev-parse --show-toplevel 2>/dev/null)/$git_common_dir" 2>/dev/null && pwd)"

    # In a worktree container, the common dir ends in .bare
    if [[ "$(basename "$git_common_dir")" == ".bare" ]]; then
        dirname "$git_common_dir"
        return 0
    fi

    return 1
}

# Check if the current directory is inside a worktree container.
# Returns 0 (true) if yes, 1 (false) if standard clone or not in a repo.
_is_worktree_repo() {
    _wt_container_root &>/dev/null
}

# ---------------------------------------------------------------------------
# Clone helpers
# ---------------------------------------------------------------------------

# Clone a single URL to its derived path under base_dir. No cd.
# Usage: _clone_one <url> <base_dir> [git-clone-flags...]
_clone_one() {
    local url="$1" base_dir="$2"
    shift 2
    local host path target_dir
    host=$(_clone_parse_host "$url")
    path=$(_clone_parse_path "$url")
    target_dir="$base_dir/$host/$path"
    if [[ -d "$target_dir" ]]; then
        echo "Already exists: $target_dir" >&2
        return 0
    fi
    echo "Cloning $url -> $target_dir"
    mkdir -p "$(dirname "$target_dir")"
    git clone "$@" "$url" "$target_dir"
}

# Clone all repos in a GitHub org or user account.
_clone_github_org() {
    local host="$1" org="$2" base_dir="$3"
    shift 3
    if ! command -v gh &>/dev/null; then
        echo "gh is required to clone a GitHub org but was not found" >&2
        return 1
    fi
    local api_flags=()
    [[ "$host" != "github.com" ]] && api_flags+=(--hostname "$host")
    local page=1 found=0
    while true; do
        local urls
        # Try org endpoint first; fall back to user endpoint.
        urls=$(gh api "${api_flags[@]}" "orgs/$org/repos?per_page=100&page=$page" 2>/dev/null \
            | jq -r '.[].clone_url // empty' 2>/dev/null)
        if [[ -z "$urls" ]]; then
            urls=$(gh api "${api_flags[@]}" "users/$org/repos?per_page=100&page=$page" 2>/dev/null \
                | jq -r '.[].clone_url // empty' 2>/dev/null)
        fi
        [[ -z "$urls" ]] && break
        while IFS= read -r repo_url; do
            _clone_one "$repo_url" "$base_dir" "$@"
            (( found++ ))
        done <<< "$urls"
        (( page++ ))
    done
    echo "Done: $found repos processed."
    cd "$base_dir/$host/$org"
}

# Clone all projects under a GitLab group (recursive into subgroups).
_clone_gitlab_group() {
    local host="$1" group="$2" base_dir="$3"
    shift 3
    if ! command -v glab &>/dev/null; then
        echo "glab is required to clone a GitLab group but was not found" >&2
        return 1
    fi
    local encoded="${group//\//%2F}"
    local page=1 found=0
    while true; do
        local urls
        urls=$(GITLAB_HOST="$host" glab api \
            "groups/$encoded/projects?include_subgroups=true&per_page=100&archived=false&page=$page" \
            2>/dev/null | jq -r '.[].http_url_to_repo // empty' 2>/dev/null)
        [[ -z "$urls" ]] && break
        while IFS= read -r repo_url; do
            _clone_one "$repo_url" "$base_dir" "$@"
            (( found++ ))
        done <<< "$urls"
        (( page++ ))
    done
    echo "Done: $found repos processed."
    cd "$base_dir/$host/$group"
}

# Set up a worktree container from a freshly cloned bare repo.
# Usage: _clone_setup_worktree_container <target_dir>
# Expects a bare clone at <target_dir>. Rearranges it into the container
# layout and creates an initial worktree for the default branch.
_clone_setup_worktree_container() {
    local target_dir="$1"

    # Move the bare clone contents into .bare/
    local tmpbare
    tmpbare=$(mktemp -d "${target_dir}.bare.XXXX")
    # Move everything from target_dir into tmpbare, then swap.
    mv "$target_dir" "$tmpbare/repo"
    mkdir -p "$target_dir/.bare"
    mv "$tmpbare/repo/"* "$tmpbare/repo/".[!.]* "$target_dir/.bare/" 2>/dev/null
    rmdir "$tmpbare/repo" 2>/dev/null
    rmdir "$tmpbare" 2>/dev/null

    # Create .git file pointing to .bare
    echo "gitdir: .bare" > "$target_dir/.git"

    # Determine the default branch
    local default_branch
    default_branch=$(git -C "$target_dir" symbolic-ref --short refs/remotes/origin/HEAD 2>/dev/null)
    default_branch="${default_branch#origin/}"
    [[ -z "$default_branch" ]] && default_branch="main"

    # Create the initial worktree. Suppress output so it doesn't mix with
    # the branch name we echo back to the caller.
    if ! git -C "$target_dir" worktree add "$default_branch" "$default_branch" &>/dev/null; then
        # Branch might not exist by that name; try with remote tracking
        git -C "$target_dir" worktree add "$default_branch" "origin/$default_branch" --checkout &>/dev/null
    fi

    echo "$default_branch"
}

# ---------------------------------------------------------------------------
# clone — main entry point
# ---------------------------------------------------------------------------
# Clone a repo to $DEVELOPER_DIR/<host>/<org>/<repo> and cd into it.
#
# Usage:
#   clone <url>             Standard clone
#   clone --wt <url>        Clone as a worktree container
#   clone [flags] <url>     Pass extra flags through to git clone
#
# If the URL points to a GitHub org/user (single path segment) or a GitLab
# group, clones all repos in that org/group.
#
# Flags must come before the URL (e.g., clone --wt <url>), not after.
clone() {
    local worktree_mode=false
    local extra_args=()
    local url=""

    # Parse arguments: pull out --wt flag, collect the rest.
    for arg in "$@"; do
        case "$arg" in
            --wt) worktree_mode=true ;;
            *)    extra_args+=("$arg") ;;
        esac
    done

    # URL is always the last non-flag argument.
    if [[ ${#extra_args[@]} -eq 0 ]]; then
        echo "Usage: clone [--wt] [git-clone-options] <repository-url>" >&2
        return 1
    fi
    url="${extra_args[-1]}"
    unset 'extra_args[-1]'

    local base_dir="${DEVELOPER_DIR:-$HOME/Developer}"
    local host path
    host=$(_clone_parse_host "$url")
    path=$(_clone_parse_path "$url")

    # --- Org/group cloning (not compatible with --wt) ---

    # GitHub: a single path segment means org or user — clone all repos.
    if [[ "$host" == *github* ]]; then
        local depth
        depth=$(awk -F/ '{print NF}' <<< "$path")
        if [[ "$depth" -eq 1 ]]; then
            if $worktree_mode; then
                echo "--wt is not supported for org-level clones" >&2
                return 1
            fi
            _clone_github_org "$host" "$path" "$base_dir" "${extra_args[@]}"
            return
        fi

    # GitLab: query the projects API to distinguish a project from a group.
    elif [[ "$host" == *gitlab* ]]; then
        if ! command -v glab &>/dev/null; then
            echo "glab is required for GitLab URLs but was not found" >&2
            return 1
        fi
        local encoded="${path//\//%2F}"
        local project_url
        project_url=$(GITLAB_HOST="$host" glab api "projects/$encoded" 2>/dev/null \
            | jq -r '.http_url_to_repo // empty' 2>/dev/null)
        if [[ -z "$project_url" ]]; then
            if $worktree_mode; then
                echo "--wt is not supported for group-level clones" >&2
                return 1
            fi
            _clone_gitlab_group "$host" "$path" "$base_dir" "${extra_args[@]}"
            return
        fi
    fi

    # --- Single-repo clone ---

    local target_dir="$base_dir/$host/$path"

    if [[ -d "$target_dir" ]]; then
        echo "Already exists: $target_dir" >&2
        if $worktree_mode && [[ -f "$target_dir/.git" ]]; then
            # Already a worktree container — cd into the default worktree.
            local default_branch
            default_branch=$(git -C "$target_dir" symbolic-ref --short refs/remotes/origin/HEAD 2>/dev/null)
            default_branch="${default_branch#origin/}"
            [[ -z "$default_branch" ]] && default_branch="main"
            if [[ -d "$target_dir/$default_branch" ]]; then
                _cdfzf_record "$base_dir" "$host/$path/$default_branch"
                cd "$target_dir/$default_branch"
            else
                cd "$target_dir"
            fi
        else
            _cdfzf_record "$base_dir" "$host/$path"
            cd "$target_dir"
        fi
        return 0
    fi

    echo "Cloning $url -> $target_dir"
    mkdir -p "$(dirname "$target_dir")"

    if $worktree_mode; then
        # Clone bare, then set up the container structure.
        if ! git clone --bare "${extra_args[@]}" "$url" "$target_dir"; then
            return 1
        fi
        local default_branch
        default_branch=$(_clone_setup_worktree_container "$target_dir")
        _cdfzf_record "$base_dir" "$host/$path/$default_branch"
        cd "$target_dir/$default_branch"
    else
        if git clone "${extra_args[@]}" "$url" "$target_dir"; then
            _cdfzf_record "$base_dir" "$host/$path"
            cd "$target_dir"
        else
            return 1
        fi
    fi
}

# ---------------------------------------------------------------------------
# convert-wt — convert a standard clone to a worktree container
# ---------------------------------------------------------------------------
# Converts the current repo from a standard clone to a worktree container.
# The working tree moves into a subdirectory named after the current branch.
#
# Usage: convert-wt
#
# Must be run from the root of a standard clone with a clean working tree.
# After conversion, you'll be cd'd into the default branch worktree.
convert-wt() {
    # Must be inside a git repo.
    local toplevel
    toplevel=$(git rev-parse --show-toplevel 2>/dev/null)
    if [[ -z "$toplevel" ]]; then
        echo "Not inside a git repository." >&2
        return 1
    fi

    # Must be a standard clone, not already a worktree container.
    if _is_worktree_repo; then
        echo "Already a worktree container." >&2
        return 1
    fi

    # Must have a .git directory (not a file — that would mean we're a
    # submodule or already in some worktree arrangement).
    if [[ ! -d "$toplevel/.git" ]]; then
        echo "Expected .git directory at $toplevel/.git, found something else." >&2
        return 1
    fi

    # Check for clean working tree.
    if ! git -C "$toplevel" diff-index --quiet HEAD -- 2>/dev/null; then
        echo "Working tree has uncommitted changes. Commit or stash first." >&2
        return 1
    fi
    if [[ -n "$(git -C "$toplevel" ls-files --others --exclude-standard 2>/dev/null)" ]]; then
        echo "Working tree has untracked files. Commit or remove them first." >&2
        return 1
    fi

    local branch
    branch=$(git -C "$toplevel" branch --show-current 2>/dev/null)
    if [[ -z "$branch" ]]; then
        echo "HEAD is detached. Check out a branch first." >&2
        return 1
    fi

    echo "Converting $toplevel to worktree container..."
    echo "Current branch: $branch"

    # Strategy: clone bare from local, then set up container.
    # This is cleaner than in-place rearrangement and avoids the
    # detach-and-cleanup dance. Local clone is fast (hardlinks objects).
    local tmpdir
    tmpdir=$(mktemp -d "${toplevel}.convert.XXXX")

    if ! git clone --bare "$toplevel" "$tmpdir/.bare"; then
        echo "Bare clone failed." >&2
        rm -rf "$tmpdir"
        return 1
    fi

    # Set up .git file.
    echo "gitdir: .bare" > "$tmpdir/.git"

    # Swap: move old repo aside, move container into place *before* creating
    # the worktree. Git worktrees record absolute paths, so the worktree must
    # be created at the final location to avoid stale path references.
    local backup="${toplevel}.backup.$$"
    mv "$toplevel" "$backup"
    mv "$tmpdir" "$toplevel"

    # Now create the worktree at the final path.
    if ! git -C "$toplevel" worktree add "$branch" "$branch" 2>/dev/null; then
        git -C "$toplevel" worktree add "$branch" "origin/$branch" --checkout 2>/dev/null
    fi

    if [[ ! -d "$toplevel/$branch" ]]; then
        echo "Failed to create worktree for branch '$branch'. Restoring backup." >&2
        rm -rf "$toplevel"
        mv "$backup" "$toplevel"
        return 1
    fi

    echo "Converted. Old repo backed up to: $(basename "$backup")"
    echo "  Container: $toplevel"
    echo "  Worktree:  $toplevel/$branch"
    echo ""
    echo "Verify everything works, then remove the backup:"
    echo "  rm -rf \"$backup\""

    # Record frecency and cd into the worktree.
    local base_dir="${DEVELOPER_DIR:-$HOME/Developer}"
    local rel="${toplevel#$base_dir/}"
    _cdfzf_record "$base_dir" "$rel/$branch"
    cd "$toplevel/$branch"
}

# ---------------------------------------------------------------------------
# wt — worktree management
# ---------------------------------------------------------------------------
# Manage worktrees within a worktree container.
#
# Usage:
#   wt                  List worktrees, fzf to pick one and cd into it
#   wt [query]          Same, with fzf query prefilled
#   wt add <branch>     Create a new worktree + branch, cd into it
#   wt rm <name>        Remove a worktree directory (prompts to delete branch)
#
# Must be run from inside a worktree container (or one of its worktrees).
wt() {
    local container
    container=$(_wt_container_root)
    if [[ -z "$container" ]]; then
        echo "Not inside a worktree container." >&2
        echo "Use 'convert-wt' to convert this repo, or 'clone --wt' to clone as a container." >&2
        return 1
    fi

    local subcmd="${1:-}"

    # --- wt add <branch> ---
    if [[ "$subcmd" == "add" ]]; then
        shift
        local branch="$1"
        if [[ -z "$branch" ]]; then
            echo "Usage: wt add <branch-name>" >&2
            return 1
        fi

        if [[ -d "$container/$branch" ]]; then
            echo "Worktree '$branch' already exists." >&2
            cd "$container/$branch"
            return 0
        fi

        # If the branch exists on the remote or locally, check it out.
        # If it doesn't exist, create it (-b).
        if git -C "$container" rev-parse --verify "$branch" &>/dev/null || \
           git -C "$container" rev-parse --verify "origin/$branch" &>/dev/null; then
            git -C "$container" worktree add "$container/$branch" "$branch"
        else
            git -C "$container" worktree add -b "$branch" "$container/$branch"
        fi

        if [[ -d "$container/$branch" ]]; then
            local base_dir="${DEVELOPER_DIR:-$HOME/Developer}"
            local rel="${container#$base_dir/}"
            _cdfzf_record "$base_dir" "$rel/$branch"
            cd "$container/$branch"
        else
            echo "Failed to create worktree '$branch'." >&2
            return 1
        fi
        return 0
    fi

    # --- wt rm <name> ---
    if [[ "$subcmd" == "rm" ]]; then
        shift
        local name="$1"
        if [[ -z "$name" ]]; then
            echo "Usage: wt rm <worktree-name>" >&2
            return 1
        fi

        if [[ ! -d "$container/$name" ]]; then
            echo "No worktree '$name' in $container" >&2
            return 1
        fi

        # Don't remove if we're currently in it.
        local current_wt
        current_wt=$(pwd)
        if [[ "$current_wt" == "$container/$name" || "$current_wt" == "$container/$name/"* ]]; then
            echo "You're inside this worktree. cd out first." >&2
            return 1
        fi

        git -C "$container" worktree remove "$container/$name"
        if [[ $? -eq 0 ]]; then
            echo "Removed worktree '$name'."
            # Offer to delete the branch too.
            if command -v gum &>/dev/null; then
                if gum confirm "Also delete branch '$name'?"; then
                    git -C "$container" branch -d "$name" 2>/dev/null \
                        || git -C "$container" branch -D "$name"
                fi
            else
                echo "Delete branch '$name' too? (y/N)"
                local yn
                read -r yn
                if [[ "$yn" == [yY]* ]]; then
                    git -C "$container" branch -d "$name" 2>/dev/null \
                        || git -C "$container" branch -D "$name"
                fi
            fi
        fi
        return 0
    fi

    # --- wt [query] — list and pick ---
    local worktrees=()
    local names=()
    while IFS= read -r line; do
        # `git worktree list` output: <path> <commit> [<branch>]
        local wt_path="${line%% *}"
        # Skip the bare root itself.
        [[ "$wt_path" == "$container" ]] && continue
        local name="${wt_path##*/}"
        worktrees+=("$wt_path")
        names+=("$name")
    done < <(git -C "$container" worktree list 2>/dev/null)

    if [[ ${#names[@]} -eq 0 ]]; then
        echo "No worktrees found. Use 'wt add <branch>' to create one." >&2
        return 1
    fi

    local query="${1:-}"

    # Single match with query — auto-cd.
    if [[ -n "$query" ]]; then
        local matches=()
        local match_paths=()
        for i in "${!names[@]}"; do
            if [[ "${names[$i]}" == *"$query"* ]]; then
                matches+=("${names[$i]}")
                match_paths+=("${worktrees[$i]}")
            fi
        done
        if [[ ${#matches[@]} -eq 1 ]]; then
            local base_dir="${DEVELOPER_DIR:-$HOME/Developer}"
            local rel="${match_paths[0]#$base_dir/}"
            _cdfzf_record "$base_dir" "$rel"
            cd "${match_paths[0]}"
            return 0
        fi
    fi

    # Multiple or no query — use fzf.
    if ! command -v fzf &>/dev/null; then
        echo "Worktrees in $(basename "$container"):"
        for name in "${names[@]}"; do
            echo "  $name"
        done
        return 0
    fi

    local selected
    selected=$(printf '%s\n' "${names[@]}" | fzf --height 40% --reverse --border \
        --prompt="Worktree: " --no-sort ${query:+--query="$query"})

    if [[ -n "$selected" ]]; then
        local base_dir="${DEVELOPER_DIR:-$HOME/Developer}"
        local rel="${container#$base_dir/}/$selected"
        _cdfzf_record "$base_dir" "$rel"
        cd "$container/$selected"
    fi
}

# ---------------------------------------------------------------------------
# reorg — audit and fix repo paths
# ---------------------------------------------------------------------------
# Reorganize git repos under ~/Developer so each repo's filesystem path
# matches its origin remote (host/org/repo). Handles standard clones,
# worktree containers, repos with no remotes, and multiple remotes.
# Requires gum (brew install gum).
#
# Worktree containers are treated as single units — reorg checks the
# container's remote against the container path, not individual worktrees.
#
# Usage:
#   reorg            Dry-run: show what would move, prompt for ambiguous cases
#   reorg --apply    Actually move repos after confirmation
reorg() {
    if ! command -v gum &>/dev/null; then
        echo "gum is required but was not found (brew install gum)" >&2
        return 1
    fi

    local base_dir="${DEVELOPER_DIR:-$HOME/Developer}"
    local apply=false
    if [[ "$1" == "--apply" ]]; then
        apply=true
    fi

    local moves=()       # "src|dst" pairs queued for moving
    local skipped=()     # repos that were skipped (already correct, user declined, etc.)
    local errors=()      # repos that couldn't be resolved

    # Find all repos under base_dir.
    # We look for:
    #   1. .git directories (standard clones)
    #   2. .bare directories (worktree containers — parent is the container root)
    # We skip .git *files* (worktrees within a container) to avoid processing
    # individual worktrees as separate repos.
    local repos=()
    local seen_paths=()

    # Pass 1: worktree containers (directories containing .bare/)
    while IFS= read -r baredir; do
        local container
        container=$(dirname "$baredir")
        repos+=("$container")
        seen_paths+=("$container")
    done < <(find "$base_dir" -maxdepth 6 \
        \( -name "node_modules" -o -name ".venv" -o -name "venv" -o \
           -name "__pycache__" -o -name ".tox" -o -name "vendor" -o \
           -name "target" -o -name "build" -o -name "dist" -o \
           -name ".next" -o -name ".cache" \) -type d -prune -o \
        -name ".bare" -type d -print -prune 2>/dev/null | sort)

    # Pass 2: standard clones (.git directories), skipping anything under
    # a known worktree container.
    while IFS= read -r gitdir; do
        local repo
        repo=$(dirname "$gitdir")
        # Skip if this repo is inside a known worktree container.
        local skip=false
        for seen in "${seen_paths[@]}"; do
            if [[ "$repo" == "$seen"/* || "$repo" == "$seen" ]]; then
                skip=true
                break
            fi
        done
        $skip || repos+=("$repo")
    done < <(find "$base_dir" -maxdepth 6 \
        \( -name "node_modules" -o -name ".venv" -o -name "venv" -o \
           -name "__pycache__" -o -name ".tox" -o -name "vendor" -o \
           -name "target" -o -name "build" -o -name "dist" -o \
           -name ".next" -o -name ".cache" \) -type d -prune -o \
        -name ".git" -type d -exec dirname {} \; -prune 2>/dev/null | sort)

    gum style --bold "Found ${#repos[@]} repos under $base_dir"
    echo ""

    for repo in "${repos[@]}"; do
        local rel="${repo#$base_dir/}"

        # Gather all fetch remotes: "name url" per line.
        local remotes
        remotes=$(git -C "$repo" remote -v 2>/dev/null | grep '(fetch)' | awk '{print $1, $2}')

        # --- No remotes ---
        if [[ -z "$remotes" ]]; then
            local repo_name
            repo_name=$(basename "$repo")
            local local_target="$base_dir/local/$repo_name"
            local local_rel="local/$repo_name"

            # Already in the right place?
            if [[ "$rel" == "local/$repo_name" ]]; then
                skipped+=("$rel (already in local/)")
                continue
            fi

            gum style --foreground 214 "No remotes: $rel"
            if $apply; then
                if gum confirm "Move to $local_rel?"; then
                    moves+=("$repo|$local_target")
                else
                    skipped+=("$rel (user skipped, no remotes)")
                fi
            else
                echo "  -> would move to: $local_rel"
            fi
            echo ""
            continue
        fi

        # --- Single remote (typical case) ---
        local remote_count
        remote_count=$(echo "$remotes" | wc -l | tr -d ' ')

        local chosen_url=""
        if [[ "$remote_count" -eq 1 ]]; then
            chosen_url=$(echo "$remotes" | awk '{print $2}')
        else
            # --- Multiple remotes ---
            # Prefer origin if it exists; otherwise ask.
            local origin_url
            origin_url=$(echo "$remotes" | awk '$1 == "origin" {print $2}')
            if [[ -n "$origin_url" ]]; then
                chosen_url="$origin_url"
            else
                gum style --foreground 214 "Multiple remotes (no origin): $rel"

                # Build labels for gum choose: "remote_name -> host/path"
                local labels=()
                local urls=()
                while IFS= read -r line; do
                    local rname rurl rhost rpath
                    rname=$(echo "$line" | awk '{print $1}')
                    rurl=$(echo "$line" | awk '{print $2}')
                    urls+=("$rurl")
                    rhost=$(_clone_parse_host "$rurl")
                    rpath=$(_clone_parse_path "$rurl")
                    labels+=("$rname -> $rhost/$rpath")
                done <<< "$remotes"

                if $apply; then
                    local choice
                    choice=$(printf '%s\n' "${labels[@]}" "Skip" \
                        | gum choose --header "Pick the canonical remote:")
                    if [[ "$choice" == "Skip" || -z "$choice" ]]; then
                        skipped+=("$rel (user skipped, multiple remotes)")
                        echo ""
                        continue
                    fi
                    # Find the index of the chosen label to get the URL.
                    for i in "${!labels[@]}"; do
                        if [[ "${labels[$i]}" == "$choice" ]]; then
                            chosen_url="${urls[$i]}"
                            break
                        fi
                    done
                else
                    for label in "${labels[@]}"; do
                        echo "  possible: $label"
                    done
                    echo ""
                    continue
                fi
            fi
        fi

        # Derive the expected path from the chosen URL.
        local exp_host exp_path exp_dir exp_rel
        exp_host=$(_clone_parse_host "$chosen_url")
        exp_path=$(_clone_parse_path "$chosen_url")
        exp_dir="$base_dir/$exp_host/$exp_path"
        exp_rel="$exp_host/$exp_path"

        # Case-insensitive comparison.
        local rel_lower exp_rel_lower
        rel_lower=$(echo "$rel" | tr '[:upper:]' '[:lower:]')
        exp_rel_lower=$(echo "$exp_rel" | tr '[:upper:]' '[:lower:]')

        if [[ "$rel_lower" == "$exp_rel_lower" ]]; then
            skipped+=("$rel (correct)")
            continue
        fi

        # This repo needs to move.
        if $apply; then
            gum style --foreground 212 "Mismatch: $rel"
            echo "  origin -> $exp_rel"
            if gum confirm "Move?"; then
                moves+=("$repo|$exp_dir")
            else
                skipped+=("$rel (user declined)")
            fi
        else
            gum style --foreground 212 "Mismatch: $rel"
            echo "  -> would move to: $exp_rel"
        fi
        echo ""
    done

    # --- Summary ---
    echo ""
    if $apply; then
        gum style --bold --border double --padding "0 2" "APPLY MODE"
    else
        gum style --bold --border double --padding "0 2" "DRY RUN  (use reorg --apply to execute)"
    fi
    echo ""
    echo "${#moves[@]} repo(s) to move"
    echo "${#skipped[@]} repo(s) already correct or skipped"
    if [[ ${#errors[@]} -gt 0 ]]; then
        echo "${#errors[@]} error(s)"
        for e in "${errors[@]}"; do
            gum style --foreground 196 "  ERROR: $e"
        done
    fi
    echo ""

    if $apply && [[ ${#moves[@]} -gt 0 ]]; then
        gum style --bold "Moves to execute:"
        for entry in "${moves[@]}"; do
            local src="${entry%%|*}"
            local dst="${entry##*|}"
            echo "  $(echo "$src" | sed "s|^$base_dir/||") -> $(echo "$dst" | sed "s|^$base_dir/||")"
        done
        echo ""
        if ! gum confirm "Proceed with all moves?"; then
            echo "Aborted."
            return 0
        fi

        local moved=0 failed=0
        for entry in "${moves[@]}"; do
            local src="${entry%%|*}"
            local dst="${entry##*|}"
            local src_rel dst_rel
            src_rel=$(echo "$src" | sed "s|^$base_dir/||")
            dst_rel=$(echo "$dst" | sed "s|^$base_dir/||")
            if [[ -e "$dst" ]]; then
                gum style --foreground 196 "  CONFLICT: $dst_rel already exists, skipping $src_rel"
                (( failed++ ))
                continue
            fi
            mkdir -p "$(dirname "$dst")"
            if mv "$src" "$dst"; then
                gum style --foreground 76 "  Moved: $src_rel -> $dst_rel"
                (( moved++ ))
                # Clean up empty parent directories left behind.
                local parent
                parent=$(dirname "$src")
                while [[ "$parent" != "$base_dir" && "$parent" != "/" ]]; do
                    rmdir "$parent" 2>/dev/null || break
                    parent=$(dirname "$parent")
                done
            else
                gum style --foreground 196 "  FAILED: could not move $src_rel"
                (( failed++ ))
            fi
        done
        echo ""
        gum style --bold "Done: $moved moved, $failed failed."
    elif ! $apply && [[ ${#moves[@]} -gt 0 ]]; then
        gum style --bold "Repos that would move:"
        for entry in "${moves[@]}"; do
            local src="${entry%%|*}"
            local dst="${entry##*|}"
            echo "  $(echo "$src" | sed "s|^$base_dir/||") -> $(echo "$dst" | sed "s|^$base_dir/||")"
        done
    fi
}

# ---------------------------------------------------------------------------
# Frecency-ranked directory picker (cdr / cdw)
# ---------------------------------------------------------------------------
#
# Maintains a history file at ~/.local/share/cdfzf/history with one
# <epoch>\t<root>\t<relative-path> per visit. Repos are scored using
# Firefox-style recency-decayed frecency: visits in the last 4 hours
# count for 100 points, last day 70, last week 50, last month 30,
# older visits 10. Repos with no history fall back to .git mtime.

_CDFZF_HISTORY="${XDG_DATA_HOME:-$HOME/.local/share}/cdfzf/history"

# Record a visit to the frecency history file.
# Usage: _cdfzf_record <root> <relative-path>
_cdfzf_record() {
    local root="$1" relpath="$2"
    mkdir -p "$(dirname "$_CDFZF_HISTORY")"
    printf '%s\t%s\t%s\n' "$(date +%s)" "$root" "$relpath" >> "$_CDFZF_HISTORY"
}

# Sort repo paths by frecency score, falling back to .git mtime.
# Reads <mtime>\t<relative-path> lines on stdin, outputs sorted paths.
# Usage: _cdfzf_rank <root> < mtime_path_list
_cdfzf_rank() {
    local root="$1"
    awk -v root="$root" -v now="$(date +%s)" -v histfile="$_CDFZF_HISTORY" '
    BEGIN {
        while ((getline line < histfile) > 0) {
            n = split(line, parts, "\t")
            if (n < 3) continue
            ts = parts[1]; hroot = parts[2]; hpath = parts[3]
            if (hroot != root) continue
            age = now - ts
            if      (age < 14400) w = 100   # 4 hours
            else if (age < 86400) w = 70    # 1 day
            else if (age < 604800) w = 50   # 1 week
            else if (age < 2592000) w = 30  # 30 days
            else w = 10
            score[hpath] += w
        }
        close(histfile)
    }
    {
        mtime = $1; path = $2
        if (path in score)
            printf "%d\t%s\n", 10000000000 + score[path], path
        else
            printf "%d\t%s\n", mtime, path
    }
    ' | sort -t$'\t' -k1,1rn | cut -f2
}

# Jump to a repo or worktree under a given root directory using fzf.
# Finds both standard clones (.git directories) and individual worktrees
# (.git files pointing into a .bare/worktrees/ directory).
#
# Usage: _cdfzf <root> <prompt> [query]
# If a query is given and matches exactly one entry, cd directly without fzf.
_cdfzf() {
    local root="$1"
    local prompt="${2:-Select repo: }"
    local query="$3"

    # Collect working trees: standard clones + worktrees inside containers.
    # We find .git as both directories (standard clones) and files (worktrees
    # or container roots), then classify each one.
    local entries=()   # paths relative to root
    local mtimes=()    # corresponding mtime for each entry

    # Pass 1: standard clones (.git directories)
    local gitdirs
    mapfile -t gitdirs < <(find "$root" -maxdepth 6 \
        \( -name "node_modules" -o \
           -name ".venv" -o \
           -name "venv" -o \
           -name "__pycache__" -o \
           -name ".tox" -o \
           -name "vendor" -o \
           -name "target" -o \
           -name "build" -o \
           -name "dist" -o \
           -name ".next" -o \
           -name ".cache" \) -type d -prune -o \
        -name ".git" -type d -print -prune 2>/dev/null)

    for gd in "${gitdirs[@]}"; do
        [[ -z "$gd" ]] && continue
        local repo_dir="${gd%/.git}"
        local rel="${repo_dir#$root/}"
        entries+=("$rel")
        local mt
        mt=$(stat -f %m "$gd" 2>/dev/null || stat -c %Y "$gd" 2>/dev/null)
        mtimes+=("$mt")
    done

    # Pass 2: worktree containers (.bare directories) — list their worktrees.
    local baredirs
    mapfile -t baredirs < <(find "$root" -maxdepth 6 \
        \( -name "node_modules" -o \
           -name ".venv" -o \
           -name "venv" -o \
           -name "__pycache__" -o \
           -name ".tox" -o \
           -name "vendor" -o \
           -name "target" -o \
           -name "build" -o \
           -name "dist" -o \
           -name ".next" -o \
           -name ".cache" \) -type d -prune -o \
        -name ".bare" -type d -print -prune 2>/dev/null)

    for bd in "${baredirs[@]}"; do
        [[ -z "$bd" ]] && continue
        local container_dir
        container_dir=$(dirname "$bd")
        # List worktrees using git. Skip the bare root entry.
        while IFS= read -r wt_line; do
            local wt_path="${wt_line%% *}"
            [[ "$wt_path" == "$container_dir" ]] && continue
            [[ -d "$wt_path" ]] || continue
            local rel="${wt_path#$root/}"
            entries+=("$rel")
            local mt
            mt=$(stat -f %m "$wt_path/.git" 2>/dev/null || stat -c %Y "$wt_path/.git" 2>/dev/null || echo 0)
            mtimes+=("$mt")
        done < <(git -C "$container_dir" worktree list 2>/dev/null)
    done

    [[ ${#entries[@]} -eq 0 ]] && return

    # Build mtime\tpath lines and rank them.
    local repos
    repos=$(for i in "${!entries[@]}"; do
        printf '%s\t%s\n' "${mtimes[$i]}" "${entries[$i]}"
    done | _cdfzf_rank "$root")

    # If a query was provided, check for a single exact (substring) match
    # before launching fzf. Fuzzy matching is only used interactively.
    if [[ -n "$query" ]]; then
        local matches
        matches=$(fzf --filter="'$query" <<< "$repos")
        local count
        count=$(wc -l <<< "$matches")
        if [[ "$count" -eq 1 && -n "$matches" ]]; then
            echo "$matches"
            _cdfzf_record "$root" "$matches"
            cd "$root/$matches"
            return
        fi
    fi

    local repo_dir
    repo_dir=$(fzf --height 40% --reverse --border --prompt="$prompt" \
        --no-sort ${query:+--query="$query"} <<< "$repos")

    if [[ -n "$repo_dir" ]]; then
        _cdfzf_record "$root" "$repo_dir"
        cd "$root/$repo_dir"
    fi
}

function cdw() { _cdfzf ~/Writing "Writing: " "$1"; }
function cdr() { _cdfzf "${DEVELOPER_DIR:-$HOME/Developer}" "Repo: " "$1"; }
