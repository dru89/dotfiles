#!/usr/bin/env sh

randstr() { LC_ALL=C tr -cd 'A-Za-z0-9' < /dev/urandom | head -c "${1:-32}"; echo; }
randhex() { LC_ALL=C tr -cd 'a-f0-9' < /dev/urandom | head -c "${1:-32}"; echo; }
alias tiga='tig --all'
alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'
alias .....='cd ../../../..'
alias sudo="sudo "
alias marked='open -a "Marked 2"'

# Serve a directory over HTTP. Defaults to current directory on port 3000.
function serve() {
    local dir="${1:-.}"
    local port="${2:-3000}"
    python3 -m http.server --directory "$dir" "$port"
}

function jql() {
    local arg="${1:-.}"
    jq -C "$arg" | less -r
}

function showcert() {
    local domain="${1}"
    if [[ "${domain}" != *":"* ]]; then
        domain="${domain}:443"
    fi
    openssl s_client -connect "${domain}" </dev/null 2>/dev/null | openssl x509 -noout -text
}

clone() {
    # NOTE: flags must come before the URL (e.g. clone --bare <url>), not after.
    # git itself accepts flags in any position, but our parsing doesn't.
    local url="${@: -1}"            # URL is always the last argument; git clone flags and their values come before it
    local extra_args=("${@:1:$#-1}")  # everything before the URL is passed through to git clone as-is
    local base_dir=~/Developer

    if [[ -z "$url" ]]; then
        echo "Usage: clone [git-clone-options] <repository-url>" >&2
        return 1
    fi

    # Derive the target path under ~/Developer from the URL.
    # Strips .git suffix, handles SSH (git@host:org/repo),
    # ssh:// (ssh://git@host:port/org/repo), and HTTPS forms.
    local norm="${url%.git}"
    local target_dir
    if [[ "$norm" == git@* ]]; then
        # git@github.com:org/repo -> github.com/org/repo
        local domain="${norm#git@}"
        domain="${domain%%:*}"
        local path="${norm#*:}"
        target_dir="$base_dir/$domain/$path"
    elif [[ "$norm" == ssh://* ]]; then
        # ssh://git@host:port/org/repo -> host/org/repo (drop user and port)
        local no_proto="${norm#ssh://}"
        no_proto="${no_proto#*@}"         # strip optional user@
        local host="${no_proto%%/*}"
        host="${host%%:*}"               # strip optional :port
        local path="${no_proto#*/}"
        target_dir="$base_dir/$host/$path"
    else
        # HTTPS or any other protocol: strip scheme and use path as-is
        target_dir="$base_dir/${norm#*://}"
    fi

    if [[ -d "$target_dir" ]]; then
        echo "Already exists: $target_dir" >&2
        cd "$target_dir"
        return 0
    fi

    echo "Cloning $url -> $target_dir"
    mkdir -p "$(dirname "$target_dir")"

    if git clone "${extra_args[@]}" "$url" "$target_dir"; then
        cd "$target_dir"
    else
        return 1
    fi
}

# Jump to a git repo under a given root directory using fzf.
_cdfzf() {
    local root="$1"
    local prompt="${2:-Select repo: }"
    local repo_dir
    repo_dir=$(find "$root" -maxdepth 4 \
        \( -name "node_modules" -o \
           -name ".venv" -o \
           -name "venv" -o \
           -name "__pycache__" -o \
           -name ".tox" -o \
           -name "vendor" -o \
           -name "target" -o \
           -name "build" -o \
           -name "dist" -o \
           -name ".next" -o \
           -name ".cache" \) -type d -prune -o \
        -name ".git" -type d -exec dirname {} \; -prune 2>/dev/null | \
        sed "s|^$root/||" | \
        fzf --height 40% --reverse --border --prompt="$prompt")

    if [[ -n "$repo_dir" ]]; then
        cd "$root/$repo_dir"
    fi
}

function cdw() { _cdfzf ~/Writing "Writing: "; }
function cdr() { _cdfzf ~/Developer "Repo: "; }

# Search up the directory tree for a file matching a pattern.
# Returns the full path to the first match.
findup() {
    if [[ $# -ne 1 ]]; then
        echo "Usage: findup <pattern>" >&2
        return 1
    fi
    local pattern="$1"
    local dir="$(pwd)"
    while true; do
        local match
        match=$(find "$dir" -maxdepth 1 -name "$pattern" -print -quit 2>/dev/null)
        if [[ -n "$match" ]]; then
            echo "$match"
            return 0
        fi
        [[ "$dir" == "/" ]] && { echo "No match found for '$pattern'" >&2; return 1; }
        dir=$(dirname "$dir")
    done
}

# cd to the directory containing the first file matching a pattern,
# searching upward from the current directory.
cdup() {
    if [[ $# -ne 1 ]]; then
        echo "Usage: cdup <pattern>" >&2
        return 1
    fi
    local match
    match=$(findup "$1") && cd "$(dirname "$match")"
}

