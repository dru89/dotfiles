#!/usr/bin/env sh

randstr() { LC_ALL=C tr -cd 'A-Za-z0-9' < /dev/urandom | head -c "${1:-32}"; echo; }
randhex() { LC_ALL=C tr -cd 'a-f0-9' < /dev/urandom | head -c "${1:-32}"; echo; }
alias tiga='tig --all'
alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'
alias .....='cd ../../../..'
alias sudo="sudo "
alias marked='open -a "Marked 2"'

# Serve a directory over HTTP. Defaults to current directory on port 3000.
function serve() {
    local dir="${1:-.}"
    local port="${2:-3000}"
    python3 -m http.server --directory "$dir" "$port"
}

function jql() {
    local arg="${1:-.}"
    jq -C "$arg" | less -r
}

function showcert() {
    local domain="${1}"
    if [[ "${domain}" != *":"* ]]; then
        domain="${domain}:443"
    fi
    openssl s_client -connect "${domain}" </dev/null 2>/dev/null | openssl x509 -noout -text
}

# Internal: extract hostname from a git URL (SSH, ssh://, or HTTPS).
_clone_parse_host() {
    local norm="${1%.git}"
    if [[ "$norm" == git@* ]]; then
        local h="${norm#git@}"; echo "${h%%:*}"
    elif [[ "$norm" == ssh://* ]]; then
        local h="${norm#ssh://}"; h="${h#*@}"; h="${h%%/*}"; echo "${h%%:*}"
    else
        local h="${norm#*://}"; echo "${h%%/*}"
    fi
}

# Internal: extract the path component (no host, no .git) from a git URL.
_clone_parse_path() {
    local norm="${1%.git}"
    if [[ "$norm" == git@* ]]; then
        echo "${norm#*:}"
    elif [[ "$norm" == ssh://* ]]; then
        local p="${norm#ssh://}"; p="${p#*@}"; echo "${p#*/}"
    else
        local p="${norm#*://}"; echo "${p#*/}"
    fi
}

# Internal: clone a single URL to its derived path under base_dir. No cd.
# Usage: _clone_one <url> <base_dir> [git-clone-flags...]
_clone_one() {
    local url="$1" base_dir="$2"
    shift 2
    local host path target_dir
    host=$(_clone_parse_host "$url")
    path=$(_clone_parse_path "$url")
    target_dir="$base_dir/$host/$path"
    if [[ -d "$target_dir" ]]; then
        echo "Already exists: $target_dir" >&2
        return 0
    fi
    echo "Cloning $url -> $target_dir"
    mkdir -p "$(dirname "$target_dir")"
    git clone "$@" "$url" "$target_dir"
}

# Internal: clone all repos in a GitHub org or user account.
_clone_github_org() {
    local host="$1" org="$2" base_dir="$3"
    shift 3
    if ! command -v gh &>/dev/null; then
        echo "gh is required to clone a GitHub org but was not found" >&2
        return 1
    fi
    local api_flags=()
    [[ "$host" != "github.com" ]] && api_flags+=(--hostname "$host")
    local page=1 found=0
    while true; do
        local urls
        # Try org endpoint first; fall back to user endpoint.
        urls=$(gh api "${api_flags[@]}" "orgs/$org/repos?per_page=100&page=$page" 2>/dev/null \
            | jq -r '.[].clone_url // empty' 2>/dev/null)
        if [[ -z "$urls" ]]; then
            urls=$(gh api "${api_flags[@]}" "users/$org/repos?per_page=100&page=$page" 2>/dev/null \
                | jq -r '.[].clone_url // empty' 2>/dev/null)
        fi
        [[ -z "$urls" ]] && break
        while IFS= read -r repo_url; do
            _clone_one "$repo_url" "$base_dir" "$@"
            (( found++ ))
        done <<< "$urls"
        (( page++ ))
    done
    echo "Done: $found repos processed."
    cd "$base_dir/$host/$org"
}

# Internal: clone all projects under a GitLab group (recursive into subgroups).
_clone_gitlab_group() {
    local host="$1" group="$2" base_dir="$3"
    shift 3
    if ! command -v glab &>/dev/null; then
        echo "glab is required to clone a GitLab group but was not found" >&2
        return 1
    fi
    local encoded="${group//\//%2F}"
    local page=1 found=0
    while true; do
        local urls
        urls=$(GITLAB_HOST="$host" glab api \
            "groups/$encoded/projects?include_subgroups=true&per_page=100&archived=false&page=$page" \
            2>/dev/null | jq -r '.[].http_url_to_repo // empty' 2>/dev/null)
        [[ -z "$urls" ]] && break
        while IFS= read -r repo_url; do
            _clone_one "$repo_url" "$base_dir" "$@"
            (( found++ ))
        done <<< "$urls"
        (( page++ ))
    done
    echo "Done: $found repos processed."
    cd "$base_dir/$host/$group"
}

clone() {
    # NOTE: flags must come before the URL (e.g. clone --bare <url>), not after.
    # git itself accepts flags in any position, but our parsing doesn't.
    local url="${@: -1}"           # URL is always the last argument
    local extra_args=("${@:1:$#-1}")  # everything before the URL passed through to git clone
    local base_dir=~/Developer

    if [[ -z "$url" ]]; then
        echo "Usage: clone [git-clone-options] <repository-url>" >&2
        return 1
    fi

    local host path
    host=$(_clone_parse_host "$url")
    path=$(_clone_parse_path "$url")

    # GitHub: a single path segment means org or user — clone all repos.
    if [[ "$host" == *github* ]]; then
        local depth
        depth=$(awk -F/ '{print NF}' <<< "$path")
        if [[ "$depth" -eq 1 ]]; then
            _clone_github_org "$host" "$path" "$base_dir" "${extra_args[@]}"
            return
        fi

    # GitLab: query the projects API to distinguish a project from a group.
    # A project response includes http_url_to_repo; a group path 404s on that endpoint.
    elif [[ "$host" == *gitlab* ]]; then
        if ! command -v glab &>/dev/null; then
            echo "glab is required for GitLab URLs but was not found" >&2
            return 1
        fi
        local encoded="${path//\//%2F}"
        local project_url
        project_url=$(GITLAB_HOST="$host" glab api "projects/$encoded" 2>/dev/null \
            | jq -r '.http_url_to_repo // empty' 2>/dev/null)
        if [[ -z "$project_url" ]]; then
            _clone_gitlab_group "$host" "$path" "$base_dir" "${extra_args[@]}"
            return
        fi
    fi

    # Direct single-repo clone.
    local target_dir="$base_dir/$host/$path"
    if [[ -d "$target_dir" ]]; then
        echo "Already exists: $target_dir" >&2
        cd "$target_dir"
        return 0
    fi
    echo "Cloning $url -> $target_dir"
    mkdir -p "$(dirname "$target_dir")"
    if git clone "${extra_args[@]}" "$url" "$target_dir"; then
        cd "$target_dir"
    else
        return 1
    fi
}

# Jump to a git repo under a given root directory using fzf.
_cdfzf() {
    local root="$1"
    local prompt="${2:-Select repo: }"
    local repo_dir
    repo_dir=$(find "$root" -maxdepth 6 \
        \( -name "node_modules" -o \
           -name ".venv" -o \
           -name "venv" -o \
           -name "__pycache__" -o \
           -name ".tox" -o \
           -name "vendor" -o \
           -name "target" -o \
           -name "build" -o \
           -name "dist" -o \
           -name ".next" -o \
           -name ".cache" \) -type d -prune -o \
        -name ".git" -type d -exec dirname {} \; -prune 2>/dev/null | \
        sed "s|^$root/||" | \
        fzf --height 40% --reverse --border --prompt="$prompt")

    if [[ -n "$repo_dir" ]]; then
        cd "$root/$repo_dir"
    fi
}

function cdw() { _cdfzf ~/Writing "Writing: "; }
function cdr() { _cdfzf ~/Developer "Repo: "; }

# Search up the directory tree for a file matching a pattern.
# Returns the full path to the first match.
findup() {
    if [[ $# -ne 1 ]]; then
        echo "Usage: findup <pattern>" >&2
        return 1
    fi
    local pattern="$1"
    local dir="$(pwd)"
    while true; do
        local match
        match=$(find "$dir" -maxdepth 1 -name "$pattern" -print -quit 2>/dev/null)
        if [[ -n "$match" ]]; then
            echo "$match"
            return 0
        fi
        [[ "$dir" == "/" ]] && { echo "No match found for '$pattern'" >&2; return 1; }
        dir=$(dirname "$dir")
    done
}

# cd to the directory containing the first file matching a pattern,
# searching upward from the current directory.
cdup() {
    if [[ $# -ne 1 ]]; then
        echo "Usage: cdup <pattern>" >&2
        return 1
    fi
    local match
    match=$(findup "$1") && cd "$(dirname "$match")"
}

